# ==============================================================================
# MINI-HEROKU ENVIRONMENT CONFIGURATION TEMPLATE (.env.example)
# ==============================================================================

# Authentication Mode
# Options: 'supabase' (default) or 'local' (developer fallback mode for local testing)
MINI_HEROKU_AUTH_MODE=supabase

# Backend Database Configuration (e.g., Supabase PostgreSQL or local SQLite)
# For Supabase PostgreSQL, use format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=sqlite:///./data/mini_heroku.db

# ------------------------------------------------------------------------------
# SUPABASE CONFIGURATION (Required when MINI_HEROKU_AUTH_MODE=supabase)
# ------------------------------------------------------------------------------

# Project URL: Found in Dashboard -> Project Settings -> API -> Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public Key: Found in Dashboard -> Project Settings -> API -> Project API Keys (anon/public)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret: Found in Dashboard -> Project Settings -> API -> JWT Settings -> JWT Secret
# Used by backend to verify user tokens locally via HMAC-SHA256 (HS256)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# ------------------------------------------------------------------------------
# DEVELOPER FALLBACK CONFIGURATION (Optional)
# ------------------------------------------------------------------------------
# JWT_SECRET=your-custom-local-secret-here

